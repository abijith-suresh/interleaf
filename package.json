{
  "name": "interleaf",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "verify": "bun run typecheck && bun run typecheck:node && bun run lint && bun run format:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/geist": "^5.1.0",
    "fuse.js": "^7.1.0",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "marked": "^15.0.12",
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^25.6.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "eslint": "^9.39.0",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.3.2",
    "vite-plugin-pwa": "^1.0.0",
    "vite-plugin-solid": "^2.11.6"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,jsx,css,html,json,md}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
